# ─────────────────────────────────────────────────────────────
# Run Coach — omgevingsvariabelen
# Kopieer dit bestand naar .env.local en vul de echte waarden in.
# .env.local is gitignored en mag NOOIT worden gecommit.
# ─────────────────────────────────────────────────────────────

# Supabase project (Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://JOUW_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...   # anon/public key – mag in de frontend-bundle

# ⚠️  ALLEEN SERVER-SIDE — gebruik NOOIT het VITE_ prefix voor onderstaande keys.
# Met VITE_ prefix wordt een variabele gebakken in de client-bundle en
# is zichtbaar voor elke gebruiker van de app.

# Supabase service role – bypast RLS, nooit client-side gebruiken
# (gebruikt door Edge Functions via Supabase runtime)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key – momenteel ONGEBRUIKT in de codebase
OPENAI_API_KEY=

# ElevenLabs API key – alleen lokaal via: node tools/generate-cues.mjs
ELEVENLABS_API_KEY=
